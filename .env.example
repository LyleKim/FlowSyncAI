# GROQ_API_KEY: Required for Groq AI checklist generation API.
GROQ_API_KEY="GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Django
DJANGO_SECRET_KEY="django-insecure-flowsync-ai-key-development-only"
DEBUG="True"

# MySQL Database (defaults match docker-compose.yml)
DB_NAME="flowsync"
DB_USER="admin"
DB_PASSWORD="password"
DB_HOST="127.0.0.1"
DB_PORT="3306"
